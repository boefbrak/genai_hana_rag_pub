<mvc:View
    controllerName="genai.rag.app.controller.Chat"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:l="sap.ui.layout">
    <Page title="RAG Chat Assistant" class="chatPage">
        <headerContent>
            <Button text="Documents" icon="sap-icon://document" press=".onNavToUpload"/>
            <Button icon="sap-icon://add" tooltip="New Chat" press=".onNewSession" type="Emphasized"/>
        </headerContent>
        <content>
            <HBox height="100%" width="100%">
                <VBox width="250px" class="sapUiSmallMarginEnd">
                    <Toolbar>
                        <Title text="Sessions" level="H5"/>
                    </Toolbar>
                    <List
                        id="sessionList"
                        mode="SingleSelectMaster"
                        selectionChange=".onSessionSelect"
                        items="{sessions>/value}"
                        noDataText="No sessions yet">
                        <StandardListItem
                            title="{sessions>title}"
                            type="Active"/>
                    </List>
                </VBox>

                <VBox height="100%" width="100%" class="chatArea">
                    <ScrollContainer id="chatScroll" height="100%" vertical="true" class="sapUiSmallMargin chatMessages">
                        <List
                            id="messageList"
                            items="{messages>/}"
                            showNoData="false"
                            showSeparators="None">
                            <CustomListItem type="Inactive">
                                <VBox class="{= ${messages>role} === 'user' ? 'chatMessageUser' : 'chatMessageAssistant'}">
                                    <HBox alignItems="Center">
                                        <core:Icon
                                            src="{= ${messages>role} === 'user' ? 'sap-icon://person-placeholder' : 'sap-icon://da'}"
                                            class="sapUiSmallMarginEnd"
                                            size="1rem"/>
                                        <Label text="{= ${messages>role} === 'user' ? 'You' : 'Assistant'}" design="Bold"/>
                                    </HBox>
                                    <Text text="{messages>content}" class="sapUiSmallMarginTop messageContent"/>
                                </VBox>
                            </CustomListItem>
                        </List>
                    </ScrollContainer>

                    <Toolbar class="chatInputBar">
                        <Input
                            id="messageInput"
                            placeholder="Ask a question about your documents..."
                            width="100%"
                            submit=".onSendMessage"
                            enabled="{= !!${app>/currentSessionId}}"/>
                        <Button
                            icon="sap-icon://paper-plane"
                            press=".onSendMessage"
                            type="Emphasized"
                            enabled="{= !!${app>/currentSessionId}}"/>
                    </Toolbar>
                </VBox>
            </HBox>
        </content>
    </Page>
</mvc:View>
