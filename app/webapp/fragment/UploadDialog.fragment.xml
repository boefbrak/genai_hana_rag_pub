<core:FragmentDefinition
    xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified">
    <Dialog
        id="uploadDialog"
        title="Upload Document"
        contentWidth="450px">
        <content>
            <VBox class="sapUiSmallMargin">
                <Label text="Select a PDF, TXT, or CSV file (max 10 MB):" class="sapUiSmallMarginBottom"/>
                <u:FileUploader
                    id="dialogFileUploader"
                    fileType="pdf,txt,csv"
                    maximumFileSize="10"
                    placeholder="Choose a file..."
                    width="100%"
                    typeMissmatch=".onTypeMismatch"
                    fileSizeExceed=".onFileSizeExceed"/>
            </VBox>
        </content>
        <beginButton>
            <Button text="Upload" type="Emphasized" press=".onUploadConfirm" icon="sap-icon://upload"/>
        </beginButton>
        <endButton>
            <Button text="Cancel" press=".onUploadCancel"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>
